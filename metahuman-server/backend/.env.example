# Ollama (the LLM examiner)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Whisper (speech-to-text)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu          # or: cuda
WHISPER_COMPUTE=int8        # cpu: int8  |  gpu: float16

# Optional: forward generated speech to Unreal for MetaHuman lip-sync
# (websocket your Unreal project listens on; leave blank to disable)
UNREAL_WS=

# Optional: NVIDIA Audio2Face-3D microservice (gRPC) for phoneme-accurate lips on the
# in-browser 3D avatar — NO Unreal required. Leave blank to use the amplitude fallback.
# e.g. A2F_GRPC_URL=localhost:52000
A2F_GRPC_URL=

# Optional neural TTS voice for Piper (.onnx). If unset, falls back to pyttsx3.
PIPER_VOICE=

# CORS: who may call this backend from a browser
ALLOW_ORIGINS=*
